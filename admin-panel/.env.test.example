# Admin-panel Phase-1 E2E (Playwright)
VITE_API_BASE_URL=http://127.0.0.1:3311/api

E2E_WEB_PORT=5174
E2E_WEB_BASE_URL=http://127.0.0.1:5174
E2E_API_BASE_URL=http://127.0.0.1:3311/api

# Playwright web server strategy (preferred)
PLAYWRIGHT_WEB_PORT=4173
PLAYWRIGHT_BASE_URL=http://127.0.0.1:4173
# true => you start the admin-panel yourself and Playwright only connects
PLAYWRIGHT_REUSE_WEB_SERVER=true
# true => do NOT bootstrap API/DB from Playwright; use your already-running API
PLAYWRIGHT_USE_EXISTING_BACKEND=true
# Used only when Playwright starts the frontend (REUSE_WEB_SERVER=false), or for documentation.
PLAYWRIGHT_API_BASE_URL=http://127.0.0.1:3001/api

E2E_COUNTRY=IN

E2E_ADMIN_USERNAME=phase1_admin_in
E2E_ADMIN_PASSWORD=Test@1234

E2E_VIEWER_USERNAME=phase1_org_viewer
E2E_VIEWER_PASSWORD=Test@1234

# Optional: point E2E to existing lot records in your real DB
E2E_TOKEN_EDITABLE=GT_PHASE1_EDITABLE_00001
E2E_LOT_EDITABLE_CODE=LOT_GT_PHASE1_EDITABLE_00001_1
E2E_TOKEN_FINAL=GT_PHASE1_FINAL_00001
E2E_LOT_FINAL_CODE=LOT_GT_PHASE1_FINAL_00001_1
